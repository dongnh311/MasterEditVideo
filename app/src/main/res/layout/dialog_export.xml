<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_dialog_export"
    android:padding="16dp">

    <TextView
        android:id="@+id/view_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/export_header"
        android:textColor="@color/colorWhite"
        android:textSize="16sp"
        android:textStyle="bold"
        android:paddingBottom="8dp" />

    <RadioGroup
        android:id="@+id/radio_resolution"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <RadioButton
            android:id="@+id/radio_hd"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/export_resolution_hd"
            android:textColor="@color/colorWhite"
            android:buttonTint="@color/colorPrimary"
            android:checked="true" />

        <RadioButton
            android:id="@+id/radio_full_hd"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/export_resolution_full_hd"
            android:textColor="@color/colorWhite"
            android:buttonTint="@color/colorPrimary" />

        <RadioButton
            android:id="@+id/radio_qhd"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/export_resolution_qhd"
            android:textColor="@color/colorWhite"
            android:buttonTint="@color/colorPrimary" />

    </RadioGroup>

    <ProgressBar
        android:id="@+id/progress_bar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:max="100"
        android:progress="0"
        android:progressTint="@color/colorPrimary"
        android:progressBackgroundTint="@color/colorDark"
        android:visibility="gone" />

    <TextView
        android:id="@+id/text_progress"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:textColor="@color/colorWhite"
        android:textSize="12sp"
        android:layout_marginTop="4dp"
        android:visibility="gone" />

    <TextView
        android:id="@+id/text_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:textColor="@color/colorPrimary"
        android:textSize="14sp"
        android:layout_marginTop="12dp"
        android:visibility="gone" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="16dp">

        <TextView
            android:id="@+id/btn_cancel"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/common_btn_cancel"
            android:textColor="@color/colorWhite"
            android:textSize="14sp"
            android:textAllCaps="true" />

        <TextView
            android:id="@+id/btn_export"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/export_btn_start"
            android:textColor="@color/colorPrimary"
            android:textSize="14sp"
            android:textAllCaps="true" />

    </LinearLayout>

</LinearLayout>
